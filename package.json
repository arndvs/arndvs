{
    "name": "arndvs",
    "version": "0.1.0",
    "packageManager": "pnpm@10.33.0",
    "private": true,
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "verify": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm build",
        "seed:changelog": "pnpm exec tsx scripts/seed-changelog.ts",
        "changelog:digest": "pnpm exec tsx scripts/generate-changelog-digest.ts",
        "typegen": "sanity schema extract --enforce-required-fields && sanity typegen generate",
        "prepare": "husky"
    },
    "dependencies": {
        "@react-email/components": "^0.5.6",
        "@react-email/render": "^1.3.2",
        "@sanity/client": "^7.21.0",
        "@sanity/icons": "^3.7.4",
        "@sanity/image-url": "^2.1.1",
        "@sanity/preview-url-secret": "^4.0.5",
        "@sanity/vision": "^5.21.0",
        "@vercel/analytics": "^2.0.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "feed": "^5.2.0",
        "framer-motion": "^12.23.24",
        "geist": "^1.7.0",
        "lucide-react": "^0.454.0",
        "mermaid": "^11.14.0",
        "next": "16.2.3",
        "next-sanity": "^12.2.2",
        "next-themes": "^0.4.6",
        "openai": "^6.34.0",
        "radix-ui": "^1.4.3",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "react-zoom-pan-pinch": "^4.0.3",
        "resend": "^6.1.2",
        "sanity": "^5.21.0",
        "server-only": "^0.0.1",
        "shiki": "^4.0.2",
        "sonner": "^1.7.4",
        "tailwind-indicator": "^0.1.0",
        "tailwind-merge": "^2.5.5"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.14",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^22",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "dotenv": "^17.4.1",
        "eslint": "^9",
        "eslint-config-next": "16.2.3",
        "eslint-plugin-unused-imports": "^4.4.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "postcss": "^8.5",
        "prettier": "^3.8.2",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tailwindcss": "^4.1.14",
        "tsx": "^4",
        "tw-animate-css": "1.3.3",
        "typescript": "^5",
        "vitest": "^4.1.4"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,json,css,md,mdx}": "prettier --write"
    }
}
